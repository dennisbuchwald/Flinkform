{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "perform/field-text",
	"version": "0.1.0",
	"title": "Text Field",
	"category": "perform",
	"icon": "editor-textcolor",
	"description": "A single-line text input.",
	"keywords": ["text", "input", "field"],
	"textdomain": "perform-forms",
	"parent": ["perform/form"],
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"label": {
			"type": "string",
			"default": "Text"
		},
		"placeholder": {
			"type": "string",
			"default": ""
		},
		"required": {
			"type": "boolean",
			"default": false
		},
		"helpText": {
			"type": "string",
			"default": ""
		},
		"fieldName": {
			"type": "string",
			"default": ""
		}
	},
	"usesContext": ["perform/formId"],
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
