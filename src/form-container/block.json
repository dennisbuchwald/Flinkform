{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "perform/form",
	"version": "0.1.0",
	"title": "PerForm Form",
	"category": "perform",
	"icon": "feedback",
	"description": "A form container. Add field blocks inside to build your form.",
	"keywords": ["form", "contact", "perform"],
	"textdomain": "perform-forms",
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"anchor": true
	},
	"attributes": {
		"formId": {
			"type": "string",
			"default": ""
		},
		"title": {
			"type": "string",
			"default": ""
		},
		"submitLabel": {
			"type": "string",
			"default": "Send"
		},
		"successMessage": {
			"type": "string",
			"default": "Thank you! Your message has been sent."
		},
		"notifications": {
			"type": "object",
			"default": {}
		},
		"appearance": {
			"type": "object",
			"default": {}
		},
		"customCSS": {
			"type": "string",
			"default": ""
		}
	},
	"providesContext": {
		"perform/formId": "formId",
		"perform/appearance": "appearance"
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
