# Files & folders excluded from the distributed plugin zip.
# Consumed by `wp-scripts plugin-zip` (npm run plugin-zip) and mirrored by the
# manual rsync build. The compiled `build/` directory is NOT listed — it must
# ship in the zip (it is git-ignored, regenerated via `npm run build`).

/.git
/.github
/.claude
/.dev
/.wordpress-org
/_wporg-svn
/node_modules
/src

# Developer-only contract docs (not for end users).
includes/Bridge/README.md

/.distignore
/.editorconfig
/.gitignore
/.phpcs.xml.dist
/composer.json
/composer.lock
/package.json
/package-lock.json
/deploy.sh

# Development docs — the only doc that ships is readme.txt (WordPress.org).
# Explicit entries + glob guards so a new dev doc never leaks into the
# distributed zip (WP.org flags internal specs/prompts inside a plugin).
/readme.md
/AUDIT_PROMPT.md
/*_PROMPT.md
/PERFORM_*.md
/FLINKFORM_*.md
/CONTINUE_PROMPT.md
/INITIAL_PROMPT.md
/PERFORM_LANDINGPAGE.md
/PERFORM_ROADMAP.md
/PERFORM_SPEC.md

*.zip
.DS_Store
Thumbs.db
.gitkeep
/tests
