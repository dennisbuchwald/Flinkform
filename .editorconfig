# https://editorconfig.org
# WordPress coding standards: tabs for indentation, LF endings, UTF-8.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab

# JSON / YAML / Markdown traditionally use spaces.
[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
